<%- include('../layout', {
  title: 'Product Management',
  body: `
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3>Product Management</h3>
      <a href="/admin/products/new" class="btn btn-primary btn-sm">Add Product</a>
    </div>

    <table class="table table-striped align-middle">
      <thead class="table-dark">
        <tr>
          <th>#</th><th>Name</th><th>Price</th><th>Discount</th><th>Stock</th><th>Category</th><th>Actions</th>
        </tr>
      </thead>
      <tbody>
        ${products.map((p, i) => `
          <tr>
            <td>${i + 1}</td>
            <td>${p.name}</td>
            <td>₹${p.price}</td>
            <td>${p.discount}%</td>
            <td>${p.stock}</td>
            <td>${p.category || '-'}</td>
            <td>
              <a href="/admin/products/${p._id}/edit" class="btn btn-warning btn-sm">Edit</a>
              <form action="/admin/products/${p._id}?_method=DELETE" method="POST" class="d-inline">
                <button class="btn btn-danger btn-sm" onclick="return confirm('Delete product?')">Delete</button>
              </form>
            </td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  `
}) %>
